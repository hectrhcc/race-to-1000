---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Stats from '../components/Stats.astro';
import PlayerCard from '../components/PlayerCard.astro';
import Footer from '../components/Footer.astro';

import playersData from '../data/players.json';
import type { Player } from '../types/player';

const players = playersData as Player[];

// Sort by goals descending
const sorted = [...players].sort((a, b) => b.goals - a.goals);
const totalGoals = players.reduce((sum, p) => sum + p.goals, 0);
const lastUpdated = players.reduce((latest, p) =>
  p.updatedAt > latest ? p.updatedAt : latest, '');
---

<BaseLayout
  title="Race to 1000 — La carrera por los 1000 goles"
  description={`Sigue los goles oficiales de los ${players.length} mejores goleadores activos del mundo. Ranking en tiempo real, estadísticas y la carrera hacia los 1000 goles.`}
>
  <!-- Header -->
  <Header
    totalGoals={totalGoals}
    playerCount={players.length}
    lastUpdated={lastUpdated}
  />

  <main>
    <!-- Stats Overview -->
    <div class="container">
      <Stats players={players} totalGoals={totalGoals} lastUpdated={lastUpdated} />
    </div>

    <!-- Player Cards Grid -->
    <section class="players-section">
      <div class="container">
        <div class="players-section-header">
          <span class="section-label">Goleadores</span>
          <h2 class="players-title">Los 20 más letales del planeta</h2>
          <p class="players-subtitle">
            Ordenados por total de goles oficiales (club + selección nacional).
            La barra de progreso muestra qué tan cerca están de la gloria eterna: <strong>1.000 goles</strong>.
          </p>
        </div>

        <div class="players-grid stagger-children">
          {sorted.map((player, index) => (
            <PlayerCard player={player} rank={index + 1} />
          ))}
        </div>
      </div>
    </section>

    <!-- Nav to ranking page -->
    <div class="container">
      <div class="next-section-nav">
        <a href="/ranking" class="next-link">          <span>Ver ranking completo</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <Footer lastUpdated={lastUpdated} />
</BaseLayout>

<style>
main {
  padding-bottom: 2rem;
}

/* Players Section */
.players-section {
  padding: 4rem 0;
  border-top: 1px solid var(--color-border);
  background: 
    radial-gradient(ellipse 70% 50% at 50% 0%, rgba(34,197,94,0.04) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 60%, rgba(251,191,36,0.02) 0%, transparent 50%);
}

.players-section-header {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 2rem;
}

.players-title {
  font-size: clamp(1.4rem, 3vw, 1.8rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--color-text-primary);
}

.players-subtitle {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
  max-width: 560px;
  line-height: 1.6;
}

/* Grid */
.players-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}

/* Next section nav */
.next-section-nav {
  display: flex;
  justify-content: center;
  padding: 2rem 0 1rem;
}

.next-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0.75rem 1.5rem;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-text-primary);
  text-decoration: none;
  transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
}

.next-link:hover {
  background: rgba(39, 39, 42, 0.6);
  border-color: #3f3f46;
  transform: translateY(-2px);
}

.next-link svg {
  transition: transform 0.2s ease;
  color: var(--color-gold-base);
}

.next-link:hover svg {
  transform: translateX(3px);
}

@media (max-width: 640px) {
  .players-grid {
    grid-template-columns: 1fr;
  }
}
</style>
