---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ranking from '../components/Ranking.astro';
import Timeline from '../components/Timeline.astro';
import LegendsSection from '../components/LegendsSection.astro';
import Footer from '../components/Footer.astro';

import playersData from '../data/players.json';
import historyData from '../data/history.json';
import legendsData from '../data/legends.json';
import type { Player, HistoryEntry } from '../types/player';

const players = playersData as Player[];
const history = historyData as HistoryEntry[];

const lastUpdated = players.reduce((latest, p) =>
  p.updatedAt > latest ? p.updatedAt : latest, '');
---

<BaseLayout
  title="Clasificación — Race to 1000"
  description={`Ranking global, timeline de evolución y leyendas del fútbol. Sigue la carrera hacia los 1.000 goles.`}
>
  <main class="ranking-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Estás aquí">
      <div class="container">
        <ol class="breadcrumb-list">
          <li><a href="/" class="breadcrumb-link">Inicio</a></li>
          <li class="breadcrumb-sep" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </li>
          <li>
            <span class="breadcrumb-current" aria-current="page">Clasificación</span>
          </li>
        </ol>
      </div>
    </nav>

    <!-- Ranking Global -->
    <section id="ranking">
      <div class="container">
        <Ranking players={players} />
      </div>
    </section>

    <!-- Timeline / History -->
    <section id="historial">
      <div class="container">
        <Timeline players={players} history={history} />
      </div>
    </section>

    <!-- Legends Section -->
    <LegendsSection legends={legendsData} id="leyendas" />

    <!-- Footer -->
    <Footer lastUpdated={lastUpdated} />
  </main>
</BaseLayout>

<style>
.ranking-page {
  padding-bottom: 0;
}

/* ─── Breadcrumb ───────────────────────────────────────────── */
.breadcrumb {
  padding: 1rem 0 0;
  border-bottom: 1px solid var(--color-border);
  background: var(--color-bg-surface);
}

.breadcrumb-list {
  display: flex;
  align-items: center;
  gap: 6px;
  list-style: none;
  padding: 0.6rem 0;
}

.breadcrumb-link {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.breadcrumb-link:hover {
  color: var(--color-gold-base);
}

.breadcrumb-sep {
  display: flex;
  align-items: center;
  color: var(--color-text-muted);
  opacity: 0.4;
}

.breadcrumb-current {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* Smooth anchor offset for sticky navbar */
#ranking,
#historial,
#leyendas {
  scroll-margin-top: 64px;
}
</style>
