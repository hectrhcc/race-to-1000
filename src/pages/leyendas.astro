---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegendsSection from '../components/LegendsSection.astro';
import Footer from '../components/Footer.astro';

import playersData from '../data/players.json';
import legendsData from '../data/legends.json';

const lastUpdated = (playersData as { updatedAt: string }[]).reduce((latest, p) =>
  p.updatedAt > latest ? p.updatedAt : latest, '');
---

<BaseLayout
  title="Leyendas — Race to 1000"
  description="Los goleadores retirados más legendarios del fútbol mundial. Pelé, Maradona, Puskás y otras leyendas que marcaron la historia del gol."
>
  <main class="leyendas-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Estás aquí">
      <div class="container">
        <ol class="breadcrumb-list">
          <li><a href="/" class="breadcrumb-link">Inicio</a></li>
          <li class="breadcrumb-sep" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </li>
          <li>
            <span class="breadcrumb-current" aria-current="page">Leyendas</span>
          </li>
        </ol>
      </div>
    </nav>

    <!-- Legends Section -->
    <LegendsSection legends={legendsData} />

    <!-- Footer -->
    <Footer lastUpdated={lastUpdated} />
  </main>
</BaseLayout>

<style>
.leyendas-page {
  padding-bottom: 0;
}

/* ─── Breadcrumb ───────────────────────────────────────────── */
.breadcrumb {
  padding: 1rem 0 0;
  border-bottom: 1px solid var(--color-border);
  background: var(--color-bg-surface);
}

.breadcrumb-list {
  display: flex;
  align-items: center;
  gap: 6px;
  list-style: none;
  padding: 0.6rem 0;
}

.breadcrumb-link {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.breadcrumb-link:hover {
  color: var(--color-gold-base);
}

.breadcrumb-sep {
  display: flex;
  align-items: center;
  color: var(--color-text-muted);
  opacity: 0.4;
}

.breadcrumb-current {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-text-primary);
}
</style>
