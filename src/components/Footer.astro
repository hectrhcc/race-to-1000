---
export interface Props {
  lastUpdated: string;
}

const { lastUpdated } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">Race to 1000</span>
        <p class="footer-tagline">
          Seguimiento no oficial de los goleadores más letales del planeta.
          Datos actualizados automáticamente vía GitHub Actions.
        </p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">Datos</span>
          <ul>
            <li><a href="/sitemap-index.xml" target="_blank" rel="noopener">Sitemap</a></li>
            <li><a href="/robots.txt" target="_blank" rel="noopener">Robots.txt</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Info</span>
          <ul>
            <li><span class="footer-note">Fuente: estadísticas públicas</span></li>
            <li><span class="footer-note">Goles oficiales: club + selección</span></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year} Race to 1000</span>
      <div class="footer-updated">
        <span class="live-dot"></span>
        <span>Última actualización: {new Date(lastUpdated).toLocaleDateString('es-ES', {
          day: 'numeric', month: 'long', year: 'numeric'
        })}</span>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--color-border);
  padding: 3rem 0 2rem;
  background: 
    radial-gradient(ellipse 60% 40% at 50% 100%, rgba(251, 191, 36, 0.04) 0%, transparent 70%),
    radial-gradient(ellipse 80% 30% at 30% 100%, rgba(34, 197, 94, 0.03) 0%, transparent 60%);
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 3rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  max-width: 320px;
}

.footer-logo {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, #fde68a, #fbbf24);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.footer-tagline {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.footer-links {
  display: flex;
  gap: 3rem;
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.footer-col-title {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.footer-col a {
  font-size: 0.82rem;
  color: var(--color-text-secondary);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer-col a:hover { color: var(--color-text-primary); }

.footer-note {
  font-size: 0.78rem;
  color: var(--color-text-muted);
}

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1.5rem;
  border-top: 1px solid var(--color-border-subtle);
  flex-wrap: wrap;
  gap: 0.75rem;
}

.footer-copy {
  font-size: 0.78rem;
  color: var(--color-text-muted);
}

.footer-updated {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  color: var(--color-text-muted);
}

.live-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-gold-base);
  display: inline-block;
}
</style>
