---
export interface Props {
  percentage: number;
  remaining: number;
  goals: number;
  target?: number;
}

const { percentage, remaining, goals, target = 1000 } = Astro.props;
const pct = Math.min(percentage, 100);
const isComplete = remaining === 0;
---

<div class="progress-wrapper">
  <div class="progress-header">
    <div class="progress-nums tabular-nums">
      <span class="progress-current">{goals.toLocaleString('es-ES')}</span>
      <span class="progress-separator">/</span>
      <span class="progress-target">{target.toLocaleString('es-ES')}</span>
    </div>
    <span class="progress-pct" class:list={[{ 'pct-complete': isComplete }]}>
      {pct.toFixed(1)}%
    </span>
  </div>

  <div class="progress-track" role="progressbar" aria-valuenow={goals} aria-valuemin={0} aria-valuemax={target}>
    <div
      class="progress-fill"
      style={`width: ${pct}%`}
      data-width={pct}
    >
      {isComplete && <div class="progress-glow"></div>}
    </div>
  </div>

  <div class="progress-footer">
    {isComplete
      ? <span class="remaining-label complete">🏆 ¡Meta alcanzada!</span>
      : <span class="remaining-label">{remaining.toLocaleString('es-ES')} goles para llegar a {target.toLocaleString('es-ES')}</span>
    }
  </div>
</div>

<style>
.progress-wrapper {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.progress-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.progress-nums {
  display: flex;
  align-items: baseline;
  gap: 3px;
}

.progress-current {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--color-text-primary);
}

.progress-separator {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.progress-target {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.progress-pct {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-green-base);
}

.pct-complete {
  color: #4ade80;
}

.progress-track {
  background: var(--color-border);
  border-radius: 999px;
  height: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #16a34a, #22c55e, #4ade80);
  box-shadow: 0 0 10px rgba(34, 197, 94, 0.35);
  transition: width 1.2s cubic-bezier(0.34, 1.2, 0.64, 1);
  position: relative;
  width: 0%; /* starts at 0, animates to target */
}

.progress-glow {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 12px rgba(74, 222, 128, 0.8);
}

.progress-footer {
  display: flex;
  align-items: center;
}

.remaining-label {
  font-size: 0.72rem;
  color: var(--color-text-muted);
}

.remaining-label.complete {
  color: var(--color-green-base);
  font-weight: 500;
}
</style>

<script>
  // Animate progress bars on scroll into view
  document.addEventListener('DOMContentLoaded', () => {
    const fills = document.querySelectorAll<HTMLElement>('.progress-fill[data-width]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const targetWidth = el.dataset.width;
          if (targetWidth) {
            el.style.width = `${targetWidth}%`;
          }
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    fills.forEach(fill => {
      fill.style.width = '0%';
      observer.observe(fill);
    });
  });
</script>
