---
import type { Player } from '../types/player';
import ProgressBar from './ProgressBar.astro';

export interface Props {
  player: Player;
  rank: number;
}

const { player, rank } = Astro.props;

const TARGET = 1000;
const percentage = (player.goals / TARGET) * 100;
const remaining = Math.max(TARGET - player.goals, 0);

// Rank medal
const medals: Record<number, string> = { 1: '🥇', 2: '🥈', 3: '🥉' };
const medal = medals[rank];

// Format updated date
const updatedDate = new Date(player.updatedAt).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
});

// Image fallback URL (initials-based avatar)
const fallbackSrc = `https://ui-avatars.com/api/?name=${encodeURIComponent(player.name)}&size=200&background=27272a&color=f4f4f5&bold=true&format=svg`;
---

<article class="card player-card animate-fade-up" data-player-id={player.id}>
  <!-- Rank Badge -->
  <div class="rank-badge" class:list={[{ 'rank-top3': rank <= 3 }]}>
    {medal ? <span class="medal">{medal}</span> : <span class="rank-num font-display">#{rank}</span>}
  </div>

  <!-- Player Image -->
  <div class="player-img-wrap">
    <img
      src={player.image}
      alt={`Foto de ${player.name}`}
      class="player-img"
      width="96"
      height="96"
      loading="lazy"
      decoding="async"
      onerror={`this.onerror=null;this.src='${fallbackSrc}'`}
    />
    <div class="img-ring"></div>
  </div>

  <!-- Player Info -->
  <div class="player-info">
    <h2 class="player-name font-display tracking-tightest">{player.name}</h2>

    <div class="player-meta">
      <span class="player-club">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        {player.club}
      </span>
      <span class="player-country">
        <span class="flag">{player.countryFlag}</span>
        {player.country}
      </span>
    </div>

    <div class="player-pos-age">
      <span class="badge">{player.position}</span>
      <span class="badge">{player.age} años</span>
    </div>
  </div>

  <!-- Goals Number -->
  <div class="goals-display">
    <span class="goals-num font-display tracking-tightest tabular-nums gradient-text">{player.goals.toLocaleString('es-ES')}</span>
    <span class="goals-label">goles oficiales</span>
  </div>

  <!-- Progress Bar -->
  <div class="card-progress">
    <ProgressBar
      percentage={percentage}
      remaining={remaining}
      goals={player.goals}
    />
  </div>

  <!-- Footer -->
  <div class="card-footer">
    <span class="updated-label">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
      {updatedDate}
    </span>
  </div>
</article>

<style>
.player-card {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  cursor: default;
}

/* Rank Badge */
.rank-badge {
  position: absolute;
  top: 1.2rem;
  right: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--color-border);
  backdrop-filter: blur(10px);
}

.rank-badge.rank-top3 {
  background: transparent;
  border: none;
  box-shadow: none;
  backdrop-filter: none;
}

.medal { font-size: 1.4rem; line-height: 1; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)); }
.rank-num { font-size: 0.75rem; color: var(--color-text-muted); }

/* Image */
.player-img-wrap {
  position: relative;
  width: 88px;
  height: 88px;
  flex-shrink: 0;
}

.player-img {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  background: var(--color-bg-surface);
  border: 1px solid rgba(255,255,255,0.1);
  display: block;
}

.img-ring {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.05);
  pointer-events: none;
  transition: border-color 0.4s ease;
}

.player-card:hover .img-ring {
  border-color: rgba(16, 185, 129, 0.3);
}

/* Info */
.player-info {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.player-name {
  font-size: 1.2rem;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.player-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
}

.player-club,
.player-country {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.75rem;
  color: var(--color-text-secondary);
}

.player-club svg,
.player-country svg {
  opacity: 0.4;
}

.flag { font-size: 1rem; }

.player-pos-age {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 4px;
}

/* Goals Number */
.goals-display {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.goals-num {
  font-size: 3rem;
  line-height: 1;
}

.goals-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* Progress */
.card-progress {
  margin-top: 4px;
}

/* Footer */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 4px;
  border-top: 1px solid var(--color-border-subtle);
}

.updated-label {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.7rem;
  color: var(--color-text-muted);
}
</style>
